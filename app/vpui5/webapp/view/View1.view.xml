<mvc:View controllerName="vpui5.controller.View1"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <content>
            <!-- Create a title with "UI5 App V1" and a List from unnamed model, entity Books and columns ID, title and stock. Use ObjectListItem -->
            <Title text="UI5 App V5" />
            <List items="{/Books}">
                <ObjectListItem title="{title}" number="{stock}" numberUnit="pcs" />
            </List>

            

        </content>
    </Page>
</mvc:View>
