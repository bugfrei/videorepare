{
  "name": "vidprep",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@sap/cds": "^8",
    "express": "^4",
    "@cap-js/hana": "^1",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.6",
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^8",
    "@sap/ux-specification": "UI5-1.144",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-vpele": "cds watch --open vpele/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-vpui5": "cds watch --open vpui5/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-vpadmin": "cds watch --open vpadmin/webapp/index.html?sap-ui-xx-viewCache=false",
    "undeploy": "cf undeploy vidprep --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "sapux": [
    "app/vpele",
    "app/vpadmin"
  ],
  "cds": {
    "sql": {
      "native_hana_associations": false
    },
    "requires": {
      "[production]": {
        "db": "hana"
      },
      "auth": {
          "[development]": {
              "kind": "mocked",
              "users": {
                    "admin": {
                        "password": "admin",
                        "roles": [ "admin" ]
                    },
                    "user": {
                        "password": "user",
                        "roles": [ "user" ]
                    }
                }
            },
            "[production]": {
                "kind": "xsuaa"
            }
      },
      "html5-repo": true,
      "destinations": true,
      "workzone": true
    }
  }
}
